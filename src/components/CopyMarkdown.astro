---
/**
 * Copy Markdown button — appears next to edit link.
 * Fetches the raw .mdx source from GitHub and copies it to clipboard.
 * Agent-friendly: lets coding agents quickly get page content as Markdown.
 */
const { editUrl } = Astro.locals.starlightRoute;

// Derive raw GitHub URL from edit URL
// Edit URL: https://github.com/epiral/pinix-docs/edit/main/src/content/docs/zh/concepts/clips.mdx
// Raw URL:  https://raw.githubusercontent.com/epiral/pinix-docs/main/src/content/docs/zh/concepts/clips.mdx
let rawUrl = "";
if (editUrl) {
  const editStr = typeof editUrl === "string" ? editUrl : editUrl.toString();
  rawUrl = editStr
    .replace("github.com", "raw.githubusercontent.com")
    .replace("/edit/", "/");
}
---

{
  rawUrl && (
    <copy-markdown data-url={rawUrl}>
      <button class="copy-md-btn sl-flex print:hidden" title="Copy page as Markdown (agent-friendly)">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect width="14" height="14" x="8" y="8" rx="2" ry="2"/>
          <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/>
        </svg>
        <span class="label">Copy Markdown</span>
        <span class="copied" hidden>Copied!</span>
      </button>
    </copy-markdown>
  )
}

<script>
  class CopyMarkdown extends HTMLElement {
    constructor() {
      super();
      const btn = this.querySelector("button");
      const url = this.dataset.url;
      if (!btn || !url) return;

      btn.addEventListener("click", async () => {
        try {
          const res = await fetch(url);
          if (!res.ok) throw new Error(`${res.status}`);
          let text = await res.text();
          // Strip frontmatter
          text = text.replace(/^---[\s\S]*?---\n*/, "");
          // Strip MDX imports
          text = text.replace(/^import\s.*;\n*/gm, "");
          await navigator.clipboard.writeText(text);
          const label = btn.querySelector(".label") as HTMLElement;
          const copied = btn.querySelector(".copied") as HTMLElement;
          if (label && copied) {
            label.hidden = true;
            copied.hidden = false;
            setTimeout(() => {
              label.hidden = false;
              copied.hidden = true;
            }, 2000);
          }
        } catch (e) {
          console.error("Failed to copy markdown:", e);
        }
      });
    }
  }
  customElements.define("copy-markdown", CopyMarkdown);
</script>

<style>
  .copy-md-btn {
    gap: 0.5rem;
    align-items: center;
    background: none;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 6px;
    padding: 0.25rem 0.625rem;
    color: var(--sl-color-gray-3);
    font: inherit;
    font-size: 0.8125rem;
    cursor: pointer;
    transition: all 0.15s ease;
  }
  .copy-md-btn:hover {
    color: var(--sl-color-white);
    border-color: var(--sl-color-gray-3);
  }
  .copied {
    color: var(--sl-color-green);
  }
</style>
