---
/**
 * Override Starlight's EditLink to add a "Copy Markdown" button next to it.
 */
import CopyMarkdown from "./CopyMarkdown.astro";

const { editUrl } = Astro.locals.starlightRoute;
---

<div class="edit-actions sl-flex print:hidden">
  <CopyMarkdown />
  {
    editUrl && (
      <a href={editUrl} class="edit-link sl-flex">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
          <path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/>
        </svg>
        {Astro.locals.t("page.editLink")}
      </a>
    )
  }
</div>

<style>
  .edit-actions {
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .edit-link {
    gap: 0.5rem;
    align-items: center;
    text-decoration: none;
    color: var(--sl-color-gray-3);
    font-size: 0.8125rem;
  }
  .edit-link:hover {
    color: var(--sl-color-white);
  }
</style>
